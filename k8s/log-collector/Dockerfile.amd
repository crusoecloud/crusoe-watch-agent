# --- Build stage: install Python dependencies ---
FROM rocm/dev-ubuntu-24.04:6.3-complete AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir --break-system-packages -r requirements.txt

# --- Runtime stage ---
FROM rocm/dev-ubuntu-24.04:6.3-complete

WORKDIR /app

# Install Python and minimal tools needed by amd-bug-report.sh
# Note: rocm-smi and rocminfo are already included in the ROCm base image
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    ca-certificates \
    lsb-release \
    lshw \
    pciutils \
    dkms \
    gzip \
    && rm -rf /var/lib/apt/lists/*

# Copy pip-installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/dist-packages /usr/local/lib/python3.12/dist-packages

# Copy AMD bug report script
COPY app/amd-bug-report.sh /usr/bin/amd-bug-report.sh
RUN chmod +x /usr/bin/amd-bug-report.sh

# Copy application code
COPY app/log_collector_app.py .

# Create logs directory
RUN mkdir -p /logs && chmod 755 /logs

CMD ["python3", "log_collector_app.py"]
