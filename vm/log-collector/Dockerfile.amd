# --- Build stage: install Python dependencies ---
FROM python:3.12-slim AS builder

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# --- Runtime stage ---
FROM ubuntu:24.04

WORKDIR /app

# Install Python, ROCm SMI tools, and system tools needed by amd-bug-report.sh
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    gnupg \
    && mkdir -p /etc/apt/keyrings \
    && wget -qO- https://repo.radeon.com/rocm/rocm.gpg.key | gpg --dearmor -o /etc/apt/keyrings/rocm.gpg \
    && echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/6.3 ubuntu main" > /etc/apt/sources.list.d/rocm.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    rocm-smi \
    rocminfo \
    lsb-release \
    lshw \
    pciutils \
    dkms \
    gzip \
    dmidecode \
    && rm -rf /var/lib/apt/lists/*

# Copy pip-installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages

# Copy AMD bug report script
COPY app/amd-bug-report.sh /usr/bin/amd-bug-report.sh
RUN chmod +x /usr/bin/amd-bug-report.sh

# Copy application code
COPY app/vm_log_collector_app.py .

# Create logs directory
RUN mkdir -p /logs && chmod 755 /logs

CMD ["python3", "vm_log_collector_app.py"]
